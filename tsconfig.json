{
  "compilerOptions": {
    "module": "es2022",
    "target": "ES2022",
    "outDir": "out",
    "lib": [
      "ES2022"
    ],
    "sourceMap": true,
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "node",
      "mocha"
    ]
  },
  "exclude": [
    "node_modules",
    ".vscode-test",
    "webview-ui"
  ]
}