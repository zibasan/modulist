{
  "name": "modulist",
  "displayName": "modulist",
  "description": "A VS Code extension for managing npm packages.",
  "version": "1.0.3",
  "engines": {
    "vscode": "^1.118.0"
  },
  "publisher": "zibasan",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/zibasan/modulist"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "npm",
    "pnpm",
    "package",
    "package manager",
    "npm package",
    "dependency",
    "dependencies",
    "manager"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Modulist",
      "properties": {
        "modulist.showConfirmations": {
          "type": "boolean",
          "default": true,
          "description": "%config.showConfirmations.desc%",
          "markdownDescription": "%config.showConfirmations.desc%"
        },
        "modulist.showBundleSize": {
          "type": "boolean",
          "default": true,
          "description": "%config.showBundleSize.desc%",
          "markdownDescription": "%config.showBundleSize.desc%"
        },
        "modulist.showReadme": {
          "type": "boolean",
          "default": true,
          "description": "%config.showReadme.desc%",
          "markdownDescription": "%config.showReadme.desc%"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "modulist-container",
          "title": "Modulist",
          "icon": "$(package)"
        }
      ]
    },
    "views": {
      "modulist-container": [
        {
          "id": "modulistView",
          "name": "Packages",
          "icon": "$(package)"
        }
      ]
    },
    "commands": [
      {
        "command": "modulist.refresh",
        "title": "%command.refresh%",
        "icon": "$(refresh)"
      },
      {
        "command": "modulist.add",
        "title": "%command.add%",
        "icon": "$(add)"
      },
      {
        "command": "modulist.openInfo",
        "title": "%command.openInfo%",
        "icon": "$(globe)"
      },
      {
        "command": "modulist.showInfoOutput",
        "title": "%command.showInfoOutput%",
        "icon": "$(output)"
      },
      {
        "command": "modulist.update",
        "title": "%command.update%",
        "icon": "$(sync)"
      },
      {
        "command": "modulist.remove",
        "title": "%command.remove%",
        "icon": "$(trash)"
      },
      {
        "command": "modulist.searchLocal",
        "title": "%command.searchLocal%",
        "icon": "$(search)"
      },
      {
        "command": "modulist.searchNpmAndAction",
        "title": "%command.searchNpmAndAction%"
      },
      {
        "command": "modulist.runScript",
        "title": "%action.runScript%",
        "icon": "$(play)"
      },
      {
        "command": "modulist.updateAll",
        "title": "%action.updateAll%",
        "icon": "$(sync)"
      },
      {
        "command": "modulist.scanUnused",
        "title": "%action.scanUnused%",
        "icon": "$(eye)"
      },
      {
        "command": "modulistView.focus",
        "title": "%command.focusView%"
      },
      {
        "command": "modulist.changeVersion",
        "title": "%action.changeVersion%",
        "icon": "$(history)"
      },
      {
        "command": "modulist.togglePin",
        "title": "%action.togglePin%",
        "icon": "$(pin)"
      },
      {
        "command": "modulist.openChangelog",
        "title": "%action.openChangelog%",
        "icon": "$(book)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "modulist.openInfo",
          "when": "false"
        },
        {
          "command": "modulist.update",
          "when": "false"
        },
        {
          "command": "modulist.remove",
          "when": "false"
        },
        {
          "command": "modulist.showInfoOutput",
          "when": "false"
        },
        {
          "command": "modulist.runScript",
          "when": "false"
        },
        {
          "command": "modulist.updateAll",
          "when": "false"
        },
        {
          "command": "modulist.scanUnused",
          "when": "false"
        },
        {
          "command": "modulist.changeVersion",
          "when": "false"
        },
        {
          "command": "modulist.togglePin",
          "when": "false"
        },
        {
          "command": "modulist.openChangelog",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "modulist.add",
          "when": "view == modulistView",
          "group": "navigation@1"
        },
        {
          "command": "modulist.searchLocal",
          "when": "view == modulistView",
          "group": "navigation@2"
        },
        {
          "command": "modulist.refresh",
          "when": "view == modulistView",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "modulist.scanUnused",
          "when": "view == modulistView && viewItem == project",
          "group": "inline"
        },
        {
          "command": "modulist.runScript",
          "when": "view == modulistView && viewItem == script",
          "group": "inline"
        },
        {
          "command": "modulist.updateAll",
          "when": "view == modulistView && viewItem =~ /^category-(dep|devDep)$/",
          "group": "inline"
        },
        {
          "command": "modulist.openChangelog",
          "when": "view == modulistView && viewItem =~ /^dependency/",
          "group": "inline"
        },
        {
          "command": "modulist.openInfo",
          "when": "view == modulistView && viewItem =~ /^dependency/",
          "group": "inline"
        },
        {
          "command": "modulist.update",
          "when": "view == modulistView && viewItem == dependency-outdated",
          "group": "inline"
        },
        {
          "command": "modulist.remove",
          "when": "view == modulistView && viewItem =~ /^dependency/",
          "group": "inline"
        },
        {
          "command": "modulist.showInfoOutput",
          "when": "view == modulistView && viewItem =~ /^dependency/",
          "group": "1_actions@1"
        },
        {
          "command": "modulist.openChangelog",
          "when": "view == modulistView && viewItem =~ /^dependency/",
          "group": "1_actions@1.5"
        },
        {
          "command": "modulist.openInfo",
          "when": "view == modulistView && viewItem =~ /^dependency/",
          "group": "1_actions@2"
        },
        {
          "command": "modulist.changeVersion",
          "when": "view == modulistView && viewItem =~ /^dependency/",
          "group": "2_modifications@2"
        },
        {
          "command": "modulist.togglePin",
          "when": "view == modulistView && viewItem =~ /^dependency/",
          "group": "2_modifications@3"
        },
        {
          "command": "modulist.update",
          "when": "view == modulistView && viewItem == dependency-outdated",
          "group": "2_modifications@4"
        },
        {
          "command": "modulist.remove",
          "when": "view == modulistView && viewItem =~ /^dependency/",
          "group": "3_danger"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm check && pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm check@fix && pnpm run compile",
    "check": "pnpm biome check",
    "check@fix": "pnpm biome check --write",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.118.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "typescript": "^5.9.3"
  }
}
